          <div
            onClick={() => setIsModalOpen(true)}
            className="bg-orange-50 p-5 rounded-xl shadow-sm border border-orange-100 flex flex-col cursor-pointer hover:ring-2 hover:ring-orange-400 transition-all group"
          >
            <div className="flex justify-between items-center mb-1">
