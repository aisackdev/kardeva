    amount.toLocaleString("es-CR", { maximumFractionDigits: 0 });

  // NEW: Helper function to display dates safely in local timezone
  const formatDate = (dateString: string) => {
    if (!dateString) return "";

    // We extract the YYYY-MM-DD string part
    const [year, month, day] = dateString.split("T")[0].split("-");

    // Creating a Date(year, monthIndex, day) forces local time at 00:00 AM
    const localDate = new Date(Number(year), Number(month) - 1, Number(day));
    return localDate.toLocaleDateString();
  };

  // Clean location using Regex: removes spaces and commas from the start
