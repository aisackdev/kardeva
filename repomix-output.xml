            </ResponsiveContainer>
          </div>
        </div>
        {/* ... Cards... */}
        <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
          {/* ... Total Incomes ... */}
          <div
            onClick={() => {
              fetchIncomes();
              setIsIncomeModalOpen(true);
